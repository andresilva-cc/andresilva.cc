# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# velite generated output
/.velite

# velite-emitted assets (built from src/content/articles/*/images/, content-hashed)
/public/static

# grafex-generated OG images: committed (escape hatch active — Vercel container
# is missing system libs for WebKit, so we generate locally and ship the PNGs).
# Regenerate after editing article frontmatter or the OG template:
#   pnpm og:generate   # or just pnpm build
# Then commit the updated PNGs. SKIP_OG_BUILD=1 is set in Vercel env vars so
# the deploy never tries to regenerate.

# agent pipeline (ephemeral)
.reviews/*
!.reviews/.gitkeep
.reports/*
!.reports/.gitkeep
.claude/worktrees/
.claude/scheduled_tasks.lock
.claire/
